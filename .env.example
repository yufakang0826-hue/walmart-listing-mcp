WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
WALMART_MARKETPLACE=US
WALMART_SANDBOX=false

# Consumer ID (WM_CONSUMER.ID) from Walmart Developer Portal.
# Required by Walmart routing layer — feeds fail with "Mandatory routing headers must be present" without it.
WALMART_CONSUMER_ID=

# Consumer Channel Type UUID (WM_CONSUMER.CHANNEL.TYPE) from Walmart Developer Portal.
# Needed so feeds are tagged as SELLER_API source.
WALMART_CHANNEL_TYPE=

# WM_SVC.ENV value. Defaults to "prod" (or "stg" when WALMART_SANDBOX=true). Override only if Walmart support tells you to.
WALMART_SVC_ENV=
